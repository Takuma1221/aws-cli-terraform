# terraform.tfvars.example
# このファイルをコピーして terraform.tfvars を作成し、実際の値を入力してください。
# terraform.tfvars は .gitignore に追加することを推奨します（IP アドレスが含まれるため）。
#
# cp terraform.tfvars.example terraform.tfvars

# S3 バケット名（全世界で一意な名前にする）
bucket_name = "your-todo-app-bucket-20260307"

# WAF で許可する IP アドレス（あなたの IP を設定してください）
# 確認コマンド: curl -4 ifconfig.me
allowed_ip_v4 = ["0.0.0.0/32"]

# IPv6 を使用する場合（不要なら空リストのまま）
# 確認コマンド: curl -6 ifconfig.me
allowed_ip_v6 = []

# DynamoDB テーブル名（デフォルトのままでも OK）
dynamodb_table_name = "todos"

# Cognito User Pool 名
cognito_user_pool_name = "todo-users"

# Cognito Hosted UI のドメイン prefix（未指定なら bucket_name を流用）
cognito_domain_prefix = "your-todo-app-auth-20260314"

# ログイン後のリダイレクト先
# まずはローカル開発用の値を入れておき、CloudFront URL が確定したら置き換える
cognito_callback_urls = ["http://localhost:3000"]

# ログアウト後のリダイレクト先
cognito_logout_urls = ["http://localhost:3000"]
